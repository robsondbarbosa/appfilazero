rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function belongsToTenant(tenantId) {
      return getUserData().tenantId == tenantId;
    }
    
    function isTenantAdmin(tenantId) {
      return belongsToTenant(tenantId) && getUserData().role == 'TENANT_ADMIN';
    }
    
    function isSuperAdmin() {
      return getUserData().role == 'SUPER_ADMIN';
    }
    
    // Users collection
    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // Tenants collection - Public read for landing pages
    match /tenants/{tenantId} {
      allow read: if true;
      allow create: if isAuthenticated() && isSuperAdmin();
      allow update: if isAuthenticated() && (isTenantAdmin(tenantId) || isSuperAdmin());
      allow delete: if isAuthenticated() && isSuperAdmin();
    }
    
    // Services collection
    match /services/{serviceId} {
      allow read: if true;
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.tenantId);
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }
    
    // Professionals collection
    match /professionals/{professionalId} {
      allow read: if true;
      allow create: if isAuthenticated() && isTenantAdmin(request.resource.data.tenantId);
      allow update: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
      allow delete: if isAuthenticated() && isTenantAdmin(resource.data.tenantId);
    }
    
    // Appointments collection
    match /appointments/{appointmentId} {
      allow read: if isAuthenticated() && (
        belongsToTenant(resource.data.tenantId) ||
        resource.data.clientEmail == request.auth.token.email
      );
      allow create: if true; // Clients can book without login
      allow update: if isAuthenticated() && (
        isTenantAdmin(resource.data.tenantId) ||
        resource.data.clientEmail == request.auth.token.email
      );
    }
    
    // Payments collection - Only via Cloud Functions
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && belongsToTenant(resource.data.tenantId);
      allow write: if false;
    }
    
    // Blocked slots
    match /blockedSlots/{slotId} {
      allow read: if true;
      allow write: if isAuthenticated() && isTenantAdmin(request.resource.data.tenantId);
    }
  }
}
